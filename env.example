# GitHub Personal Access Token
# Get it from: https://github.com/settings/tokens
# Required scopes: repo, read:user, gist
GITHUB_TOKEN=your_github_token_here

# Local LLM API endpoint
LLM_API_URL=http://10.20.124.89:11435

# LLM model name
LLM_MODEL=deepseek-r1:32b

# Output language for CLI logs, LLM prompts, fallback categories, and generated reports/lists.
# Supported values: zh, en (default: zh)
OUTPUT_LANGUAGE=zh

# Maximum number of repositories to process (optional, default: 50)
# Set to 0 to process all repositories
MAX_REPOS=50

# Enable automatic GitHub Star Lists sync (default: true)
# GitHub does not expose an official Star Lists API, so this requires a browser session cookie.
SYNC_GITHUB_LISTS=true

# Full Cookie header copied from a logged-in github.com browser request.
# Required only when SYNC_GITHUB_LISTS=true and you want the tool to create/update GitHub Star Lists.
GITHUB_SESSION_COOKIES=_octo=...; user_session=...; logged_in=yes; ...

# Preview GitHub Star Lists changes without applying them (optional, default: false)
GITHUB_LISTS_DRY_RUN=false

# Delay between GitHub web requests in milliseconds (optional, default: 1000)
GITHUB_LISTS_REQUEST_DELAY_MS=1000
