# GitHub Personal Access Token
# Get it from: https://github.com/settings/tokens
# Required scopes: repo, read:user, gist
GITHUB_TOKEN=your_github_token_here

# Local LLM API endpoint
LLM_API_URL=http://10.20.124.89:11435

# LLM model name
LLM_MODEL=deepseek-r1:32b

# Maximum number of repositories to process (optional, default: 50)
# Set to 0 to process all repositories
MAX_REPOS=50
