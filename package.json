{
  "name": "github-tag-organizer",
  "version": "1.0.0",
  "description": "LLM-powered GitHub Star Lists organizer that automatically classifies starred repositories, creates missing lists, and syncs assignments.",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "ts-node src/index.ts",
    "test": "npm run build && npm start",
    "repo:metadata": "node scripts/update-repo-metadata.js",
    "clean": "rm -rf dist/",
    "prebuild": "npm run clean"
  },
  "keywords": [
    "github",
    "github-stars",
    "star-lists",
    "llm",
    "ai",
    "organization",
    "typescript",
    "automation",
    "repository-management",
    "starred-repos",
    "github-api",
    "ollama",
    "openai",
    "productivity",
    "developer-tools"
  ],
  "author": "Inupedia",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Inupedia/Github-Tag-Organizer.git"
  },
  "bugs": {
    "url": "https://github.com/Inupedia/Github-Tag-Organizer/issues"
  },
  "homepage": "https://github.com/Inupedia/Github-Tag-Organizer#readme",
  "engines": {
    "node": ">=16.0.0"
  },
  "dependencies": {
    "@octokit/rest": "^20.0.2",
    "axios": "^1.6.2",
    "dotenv": "^16.3.1"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "ts-node": "^10.9.1",
    "typescript": "^5.3.2"
  }
}
