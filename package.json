{
  "name": "github-tag-organizer",
  "version": "1.0.0",
  "description": "A TypeScript script to organize GitHub starred repositories using LLM classification",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "ts-node src/index.ts",
    "test": "npm run build && npm start",
    "clean": "rm -rf dist/",
    "prebuild": "npm run clean"
  },
  "keywords": [
    "github",
    "llm",
    "organization",
    "typescript",
    "ai",
    "machine-learning",
    "repository-management",
    "automation",
    "starred-repos",
    "classification"
  ],
  "author": "Inupedia",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Inupedia/github-tag-organizer.git"
  },
  "bugs": {
    "url": "https://github.com/Inupedia/github-tag-organizer/issues"
  },
  "homepage": "https://github.com/Inupedia/github-tag-organizer#readme",
  "engines": {
    "node": ">=16.0.0"
  },
  "dependencies": {
    "@octokit/rest": "^20.0.2",
    "axios": "^1.6.2",
    "dotenv": "^16.3.1"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "ts-node": "^10.9.1",
    "typescript": "^5.3.2"
  }
}
